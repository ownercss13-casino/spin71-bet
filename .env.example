# --- Server Secrets (Backend only, do NOT prefix with VITE_) ---

# Firebase Configuration
FIREBASE_SERVICE_ACCOUNT= # JSON string or Base64 encoded JSON
FIREBASE_DATABASE_URL= # e.g. https://your-project-id.firebaseio.com (can be project ID only)

# Database - Retool PostgreSQL
RETOOL_API_KEY= # retool_xxxx
RETOOL_DB_URL= # postgresql://retool:PASSWORD@ep-hostname.retooldb.com/retool

# Telegram Integration
TELEGRAM_BOT_TOKEN= # 123456789:ABCDefgh
TELEGRAM_ADMIN_CHAT_ID= # -100123456789

# AI & External APIs
GEMINI_API_KEY= # AIzaSy... Obtain from https://aistudio.google.com/
TOROUTER_API_KEY= # For SMS/Proxy services
APIVERVE_API_KEY= # For specific proxy fetches
OPENAI_API_KEY= # Optional fallback

# App Settings
SESSION_SECRET= # Random long string
PORT=3000
NODE_ENV=production
AVIATOR_API_KEY= # Game secret key (e.g. #spin71bet_aviator_game109)

# --- Client Secrets (Prefix with VITE_ to expose to browser) ---
VITE_AVIATOR_API_KEY= # Must match server AVIATOR_API_KEY if used client-side
VITE_GEMINI_API_KEY= # Obtain from https://aistudio.google.com/
