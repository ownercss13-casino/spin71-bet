rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Admin Override & Server Secret Bypass
    match /{document=**} {
      allow read, write: if isAdmin() || isSecretServer();
    }

    // --- Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isSecretServer() {
      return (request.resource != null && request.resource.data.get('_serverSecret', '') == 'be4c6d81-1cb2-4249-a5cd-7822e9fa2a91_server_secret') ||
             (resource != null && resource.data.get('_serverSecret', '') == 'be4c6d81-1cb2-4249-a5cd-7822e9fa2a91_server_secret');
    }

    function isServer() {
      return isSignedIn() && request.auth.token.email == 'system.backend.bot@spin71.bet';
    }

    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'owner.css13@gmail.com' ||
        request.auth.token.email == 'cutelegend7045@gmail.com' ||
        isServer() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Users ---
    match /users/{userId} {
      allow list: if isSignedIn();
      function isValidUser(data) {
        return data.username is string && data.username.size() <= 100 &&
               data.balance is number && data.balance >= 0;
      }
      
      allow get: if isOwner(userId) || isAdmin();
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming());
      
      // Separate update rules for owners vs admins
      allow update: if isAdmin() || (
        isOwner(userId) && 
        // Prevent owners from updating sensitive financial or administrative fields
        !incoming().diff(existing()).affectedKeys().hasAny(['balance', 'totalDeposits', 'totalWithdrawals', 'referralCount', 'validReferralCount', 'totalReferralEarnings', 'referredBy', 'isAdmin', 'role']) &&
        // Allow updating profile fields
        incoming().diff(existing()).affectedKeys().hasOnly(['username', 'phoneNumber', 'profilePictureUrl', 'updatedAt', 'bankCards', 'referralCode', 'bonusesClaimed', 'lastLogin'])
      );
      
      match /transactions/{transactionId} {
        allow read, list: if isSignedIn();
        allow create: if isSignedIn() && isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read, list: if isOwner(userId) || isAdmin();
        allow update: if isOwner(userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isOwner(userId);
      }

      match /referrals/{refId} {
        allow read, list: if isSignedIn();
      }
    }

    // --- Bets ---
    match /bets/{betId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && incoming().userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- Game Config ---
    match /config/main {
      allow read, list: if true;
      allow write: if isSignedIn() && (
        request.auth.token.email == 'owner.css13@gmail.com' ||
        request.auth.token.email == 'cutelegend7045@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    match /game_settings/{gameId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /game_providers/{providerId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }                
    
    match /metadata/{docId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }
    
    match /games/{gameId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }
    
    match /global_images/{imageId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }                
    
    match /support_tickets/{ticketId} {
      function isValidTicket(data) { return data.keys().hasAll(['userId', 'subject', 'status']); }
      allow list: if isSignedIn() && (request.query.limit <= 100 || isAdmin()); // Allow listing if signed in, results will be filtered by document ownership or queries
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidTicket(incoming());
      allow update: if isAdmin() || (
        isSignedIn() && 
        resource.data.userId == request.auth.uid &&
        incoming().diff(existing()).affectedKeys().hasOnly(['messages', 'lastMessage', 'updatedAt'])
      );
    }

    // --- Transactions Root ---
    match /transactions/{transactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn() && (incoming().userId == request.auth.uid || incoming().uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- Promo Codes ---
    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /otp_verifications/{phone} {
      allow read, write: if isSecretServer(); // Server-side only
    }

    // --- Daily Rewards ---
    match /daily_rewards/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isSecretServer();
      allow write: if isSecretServer(); // Only server-side with secret
    }

    match /test_auth/{docId} {
      allow read: if true;
      allow write: if incoming()._serverSecret == 'MY_SECRET';
    }
  }
}
