rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 3. Path Variable Hardening & Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    
    // Check if user is verified. Google login is implicitly verified.
    function isVerified() { 
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.firebase.sign_in_provider == 'google.com'
      ); 
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Check if user is admin. Use email check as fallback to avoid DB lookup loops if DB is unstable
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'owner.css13@gmail.com' ||
        (request.auth.uid == 'vX1zLqR8P2h4mK6bN9jS5dFwT7y') ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['username', 'balance']) &&
               data.username is string && data.username.size() <= 100 &&
               data.balance is number && data.balance >= 0;
      }
      
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming()) && (incoming().get('role', 'user') == 'user');
      allow update: if (isVerified() && request.auth.uid == userId && 
                       (incoming().get('role', existing().role) == existing().role) &&
                       (
                         incoming().balance == existing().balance ||
                         (incoming().balance < existing().balance && incoming().get('totalWithdrawals', 0) == existing().get('totalWithdrawals', 0) + (existing().balance - incoming().balance)) ||
                         (incoming().balance > existing().balance && incoming().get('totalDeposits', 0) == existing().get('totalDeposits', 0) + (incoming().balance - existing().balance))
                       )
                      ) || isAdmin();
      
      match /transactions/{transactionId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow create: if isVerified() && request.auth.uid == userId;
      }

      match /notifications/{notifId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow create: if isAdmin();
        allow update: if isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /referrals/{refId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }
    }

    // --- Global Config & Metadata ---
    match /config/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /game_settings/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /game_providers/{providerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /global_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (request.auth.uid == ticketId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == ticketId || isAdmin());
    }

    // --- 2. Game States ---
    match /game_states/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Slot Machine Bets ---
    match /slot_bets/{betId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false; // Only server-side creation via Admin SDK
    }

    match /bets/{betId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // --- Daily Rewards ---
    match /daily_rewards/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Only server-side updates
    }

    // --- 5. Transactions Root (Financial Records) ---
    match /transactions/{transactionId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isVerified() && (incoming().userId == request.auth.uid || incoming().uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- 6. Admin Control ---
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); 
    }
  }
}
