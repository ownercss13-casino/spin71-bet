rules_version = '2';
service cloud.firestore {
    match /databases/{database}/documents {
    
    // --- Primitives & Helpers ---
    function isSignedIn() { return request.auth != null; }
    
    // Helper to get user email safely
    function getEmail() {
      return (isSignedIn() && 'email' in request.auth.token) ? request.auth.token.email : '';
    }

    // Role-based Access Control
    function isAdmin() { 
      return isSignedIn() && (
        (getEmail() == 'owner.css13@gmail.com') || 
        (getEmail() == 'cutelegend7045@gmail.com') || 
        (getEmail() == 'xsaber7644@gmil.com') || 
        (request.auth.uid == 'vxjksOlXuChe3OjfYmpxBsJcwLH2') || 
        (request.auth.uid == 'system-backend-bot-spin71') ||
        isServerBot() ||
        // Check for admin document presence
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isServerBot() { 
      return isSignedIn() && (
        request.auth.uid == 'system-backend-bot-spin71' || 
        (getEmail().startsWith('system.backend.bot') && (getEmail().endsWith('@spin71bet1.vercel.app') || getEmail().endsWith('@spin71bet1.aistudio')))
      ); 
    }

    // Secret Bypass for Backend Scripts
    function hasWriteSecret() {
      return request.resource != null && 
             request.resource.data != null && 
             ('_serverSecret' in request.resource.data) && 
             request.resource.data._serverSecret == 'be4c6d81-1cb2-4249-a5cd-7822e9fa2a91_server_secret';
    }
    
    function hasDocSecret() {
      return resource != null && 
             resource.data != null && 
             ('_serverSecret' in resource.data) && 
             resource.data._serverSecret == 'be4c6d81-1cb2-4249-a5cd-7822e9fa2a91_server_secret';
    }

    // --- Core Entity Rules ---

    // Public Entities (Read-only for all)
    match /game_settings/{document=**} {
      allow read, get, list: if true;
      allow write: if isAdmin() || hasWriteSecret();
    }
    match /global_images/{document=**} {
      allow read, get, list: if true;
      allow write: if isAdmin() || hasWriteSecret();
    }
    match /metadata/{document=**} {
      allow read, get, list: if true;
      allow write: if isAdmin() || hasWriteSecret();
    }
    match /config/{document=**} {
      allow read, get, list: if true;
      allow write: if isAdmin() || hasWriteSecret();
    }
    match /promo_codes/{document=**} {
      allow read, get, list: if true;
      allow write: if isAdmin() || hasWriteSecret();
    }
    match /bets/{document=**} {
      allow read, get, list: if true;
      allow write: if isAdmin() || hasWriteSecret();
    }

    // Users & Sub-collections
    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      
      // Allow creation/update for the user themselves or server
      allow create, update: if (isSignedIn() && request.auth.uid == userId) || isAdmin() || hasWriteSecret();
      allow delete: if isAdmin() || hasWriteSecret();
      
      // Sub-collections (Notifications, Transactions, etc.)
      match /{allSubcollections=**} {
        allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin() || hasWriteSecret() || hasDocSecret();
      }
    }

    // Financial & Support Collections
    match /daily_rewards/{userId} {
      allow read, write: if (isSignedIn() && request.auth.uid == userId) || isAdmin() || hasWriteSecret();
    }

    match /game_providers/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin() || hasWriteSecret();
    }

    match /transactions/{transactionId} {
      allow read: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin() || hasDocSecret();
      allow create: if isSignedIn() || hasWriteSecret();
      allow update, delete: if isAdmin() || hasWriteSecret();
    }

    match /slot_bets/{betId} {
      allow read: if (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid)) || isAdmin();
      allow create: if isSignedIn() || hasWriteSecret();
      allow update, delete: if isAdmin() || hasWriteSecret();
    }

    match /banner_clicks/{clickId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /support_tickets/{ticketId} {
      allow read, list: if (isSignedIn() && (resource == null || (resource.data != null && resource.data.userId == request.auth.uid))) || isAdmin() || hasDocSecret();
      allow create: if isSignedIn() || isAdmin();
      allow update, delete: if isAdmin() || hasWriteSecret();
    }

    match /telegram_subscribers/{id} { allow read, write: if true; }
    match /telegram_opt_outs/{id} { allow read, write: if true; }
    
    match /system_logs/{logId} {
      allow read: if isAdmin();
      allow create: if true;
    }

    match /otp_verifications/{phoneNumber} {
      allow get, update: if isAdmin() || hasWriteSecret() || (isSignedIn() && (resource != null && resource.data != null && resource.data.uid == request.auth.uid));
      allow create: if true;
    }

    match /admins/{adminId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Safety Net (Must be LAST) ---
    match /{document=**} {
      allow read: if isAdmin() || hasDocSecret();
      allow write: if isAdmin() || hasWriteSecret();
    }
  }
}
