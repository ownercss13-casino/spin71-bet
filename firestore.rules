rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny - Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- 3. Path Variable Hardening & Primitives ---
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Auth tokens NEVER contain custom claims. Look up roles in DB.
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'owner.css13@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- 1. Users Collection ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['username', 'balance']) &&
               data.username is string && data.username.size() <= 100 &&
               data.balance is number && data.balance >= 0;
      }
      
      allow get: if isSignedIn() && (request.auth.uid == userId || (request.auth.token.email == 'owner.css13@gmail.com') || isAdmin());
      // Secure List Query: MUST check resource.data
      allow list: if isAdmin();
      
      allow create: if isVerified() && request.auth.uid == userId && isValidUser(incoming()) && (incoming().get('role', 'user') == 'user');
      allow update: if (isVerified() && request.auth.uid == userId && 
                       incoming().balance == existing().balance && // Prevent self-balance update
                       (incoming().get('role', existing().role) == existing().role)) || isAdmin();
      
      match /transactions/{transactionId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow create: if isVerified() && request.auth.uid == userId;
      }

      match /notifications/{notifId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow create: if isAdmin();
        allow update: if isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /referrals/{refId} {
        allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
        allow write: if isAdmin();
      }
    }

    // --- Global Config & Metadata ---
    match /config/main {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /game_settings/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /game_providers/{providerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /global_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promo_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }

    match /support_tickets/{ticketId} {
      allow read: if isSignedIn() && (request.auth.uid == ticketId || isAdmin());
      allow write: if isSignedIn() && (request.auth.uid == ticketId || isAdmin());
    }

    // --- 2. Game States ---
    match /game_states/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Slot Machine Bets ---
    match /slot_bets/{betId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if false; // Only server-side creation via Admin SDK
    }

    match /bets/{betId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    // --- Daily Rewards ---
    match /daily_rewards/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Only server-side updates
    }

    // --- 5. Transactions Root (Financial Records) ---
    match /transactions/{transactionId} {
      allow get: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow list: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow create: if isVerified() && incoming().uid == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // --- 6. Admin Control ---
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; 
    }
  }
}
