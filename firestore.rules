rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Primitives & Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isServerBot() { return isSignedIn() && request.auth.uid == 'system-backend-bot-spin71'; }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdminFlag() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin;
    }
    function isDbAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getRole() == 'admin' || isAdminFlag() == true);
    }
    function getEmail() {
      return ('email' in request.auth.token) ? request.auth.token.email : '';
    }
    function isAdmin() { 
      return isSignedIn() && (
        (getEmail() == 'owner.css13@gmail.com') || 
        (getEmail() == 'cutelegend7045@gmail.com') || 
        (getEmail() == 'owner@spin71.bet') || 
        (getEmail() == 'xsaber7644@gmil.com') || 
        (request.auth.uid == 'vxjksOlXuChe3OjfYmpxBsJcwLH2') || 
        isServerBot() ||
        isDbAdmin()
      );
    }

    // --- Master Bypass for Backend Server Bot ---
    match /{document=**} {
      allow read, write: if isServerBot();
    }

    // --- Users & Sub-collections ---
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // --- Transactions ---
    match /transactions/{transactionId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Bets ---
    match /bets/{betId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Global Configurations & Images ---
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /global_images/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // --- Game Configurations ---
    match /game_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /game_providers/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Daily Rewards ---
    match /daily_rewards/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // --- Support Tickets ---
    match /support_tickets/{ticketId} {
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // --- Promo Codes ---
    match /promo_codes/{promoId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- System Admins ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // --- Telegram Services ---
    match /telegram_subscribers/{id} {
      allow read, write: if isAdmin();
    }
    
    match /telegram_opt_outs/{id} {
      allow read, write: if isAdmin();
    }

    // --- OTP Verifications ---
    match /otp_verifications/{phoneNumber} {
      allow read, write: if isAdmin();
    }

    // --- Reports ---
    match /reports/{reportId} {
      allow read, write: if isAdmin();
    }
  }
}
