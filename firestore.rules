rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'owner.css13@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Entities Validation ---
    
    function isValidUser(data) {
      return data.username is string && data.username.size() >= 3 && data.username.size() <= 32 &&
             data.balance is number && data.balance >= 0 &&
             data.role in ['user', 'agent', 'admin'] &&
             (!('phoneNumber' in data) || (data.phoneNumber is string && data.phoneNumber.size() >= 10)) &&
             (!('referredBy' in data) || (data.referredBy is string && isValidId(data.referredBy))) &&
             (!('lastDailyBonusClaimedAt' in data) || data.lastDailyBonusClaimedAt is string) &&
             (!('hasClaimedWelcomeBonus' in data) || data.hasClaimedWelcomeBonus is bool);
    }

    function isValidGameSettings(data) {
      return (!('game_id' in data) || data.game_id is string) &&
             (!('name' in data) || (data.name is string && data.name.size() <= 100)) &&
             (!('logo_url' in data) || data.logo_url is string) &&
             (!('game_url' in data) || data.game_url is string) &&
             (!('provider_option' in data) || data.provider_option is string) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidTransaction(data) {
      return data.userId is string && isValidId(data.userId) &&
             data.type in ['deposit', 'withdraw', 'bonus'] &&
             data.amount is number &&
             data.status in ['pending', 'completed', 'rejected'] &&
             data.createdAt is timestamp;
    }

    // --- Match Rules ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users
      
      allow create: if isSignedIn() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().balance == 507 && // Initial bonus enforcement
                    incoming().role == 'user';
      
      allow update: if isSignedIn() && (
        // Admin update
        isAdmin() ||
        // Self update (limited fields)
        (isOwner(userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['username', 'phoneNumber', 'updatedAt', 'balance', 'lastDailyBonusClaimedAt', 'hasClaimedWelcomeBonus']) &&
         isValidUser(incoming()))
      );
    }

    // Admin List (System Managed)
    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    // Game Settings (Public Read, All User Write)
    match /game_settings/{gameId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidGameSettings(incoming());
    }

    // Global Metadata
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Global Images (Collection based to avoid 1MB limit)
    match /global_images/{imageKey} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // Transactions (Subcollection)
    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidTransaction(incoming()) && 
                    incoming().userId == userId &&
                    incoming().status == 'pending' &&
                    incoming().createdAt == request.time;
      allow update: if isAdmin();
    }

    // Global Transactions (Admins)
    match /transactions/{transactionId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read, write: if isAdmin();
    }
  }
}
