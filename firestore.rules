rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Primitives & Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isServerBot() { 
      return isSignedIn() && (
        request.auth.uid == 'system-backend-bot-spin71' || 
        (getEmail().startsWith('system.backend.bot') && getEmail().endsWith('@spin71.bet'))
      ); 
    }
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdminFlag() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin;
    }
    function isDbAdmin() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             (getRole() == 'admin' || isAdminFlag() == true);
    }
    function getEmail() {
      return ('email' in request.auth.token) ? request.auth.token.email : '';
    }
    function isAdmin() { 
      return isSignedIn() && (
        (getEmail() == 'owner.css13@gmail.com') || 
        (getEmail() == 'cutelegend7045@gmail.com') || 
        (getEmail() == 'xsaber7644@gmil.com') || 
        (request.auth.uid == 'vxjksOlXuChe3OjfYmpxBsJcwLH2') || 
        isServerBot() ||
        isDbAdmin()
      );
    }

    // --- Cryptographically Secure Server Bypass Helper ---
    // This allows the backend server (on platforms like Render without ADC SDK credentials) 
    // to authenticate safely via a 128-bit project-specific secret.
    function hasIncomingSecret() {
      return request.resource != null && 
             request.resource.data != null && 
             ('_serverSecret' in request.resource.data) && 
             request.resource.data._serverSecret == 'be4c6d81-1cb2-4249-a5cd-7822e9fa2a91_server_secret';
    }
    function hasSavedSecret() {
      return resource != null && 
             resource.data != null && 
             ('_serverSecret' in resource.data) && 
             resource.data._serverSecret == 'be4c6d81-1cb2-4249-a5cd-7822e9fa2a91_server_secret';
    }

    // --- Master Bypass for Backend Server Bot ---
    match /{document=**} {
      allow read: if isServerBot() || hasSavedSecret();
      allow write: if isServerBot() || hasIncomingSecret();
    }

    // --- Users & Sub-collections ---
    match /users/{userId} {
      allow get: if true;
      allow list: if isSignedIn() || hasSavedSecret();
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isOwner(userId) || isAdmin() || hasIncomingSecret() || hasSavedSecret();
      allow delete: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
      
      match /used_promos/{promoId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin() || hasIncomingSecret() || hasSavedSecret();
      }

      match /{allSubcollections=**} {
        allow read: if isOwner(userId) || isAdmin() || hasSavedSecret();
        allow write: if isOwner(userId) || isAdmin() || hasIncomingSecret() || hasSavedSecret();
      }
    }

    // --- Transactions ---
    match /transactions/{transactionId} {
      allow read: if true;
      allow create: if isSignedIn() || hasIncomingSecret();
      allow update, delete: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Bets ---
    match /bets/{betId} {
      allow read: if true;
      allow create: if isSignedIn() || hasIncomingSecret();
      allow update, delete: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Global Configurations & Images ---
    match /config/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    match /global_images/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    match /metadata/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Game Configurations ---
    match /game_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    match /game_providers/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Daily Rewards ---
    match /daily_rewards/{userId} {
      allow read: if isOwner(userId) || isAdmin() || hasSavedSecret();
      allow write: if isOwner(userId) || isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Support Tickets ---
    match /support_tickets/{ticketId} {
      allow read, list: if isSignedIn() || hasSavedSecret();
      allow create: if isSignedIn() || hasIncomingSecret();
      allow update, delete: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Promo Codes ---
    match /promo_codes/{promoId} {
      allow read: if true;
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- System Admins ---
    match /admins/{adminId} {
      allow read: if isSignedIn() || hasSavedSecret();
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Telegram Services ---
    // Allow public access so unauthenticated background loops can manage signaling subscriptions smoothly
    match /telegram_subscribers/{id} {
      allow read, write: if true;
    }
    
    match /telegram_opt_outs/{id} {
      allow read, write: if true;
    }

    // --- OTP Verifications ---
    match /otp_verifications/{phoneNumber} {
      allow get: if isAdmin() || hasSavedSecret();
      allow list: if isAdmin();
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- Reports ---
    match /reports/{reportId} {
      allow read: if isAdmin() || hasSavedSecret();
      allow write: if isAdmin() || hasIncomingSecret() || hasSavedSecret();
    }

    // --- System Logs ---
    match /system_logs/{logId} {
      allow read, list: if isAdmin() || hasSavedSecret();
      allow create: if true;
      allow update, delete: if false;
    }
  }
}
