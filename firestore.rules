rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['username', 'balance']) &&
             data.username is string && data.username.size() <= 50 &&
             data.balance is number && data.balance >= 0 &&
             (!('vipLevel' in data) || data.vipLevel is int) &&
             (!('totalTurnover' in data) || data.totalTurnover is number);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['uid', 'amount', 'type', 'status']) &&
             data.uid == request.auth.uid &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'withdrawal'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('method' in data) || data.method is string) &&
             (!('senderNumber' in data) || data.senderNumber is string) &&
             (!('trxId' in data) || data.trxId is string);
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admins can list all users
      
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                       incoming().balance == 0 && // New users start with 0 balance
                       (!('vipLevel' in incoming()) || incoming().vipLevel == 0);
      
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
                      // Only allow updating certain fields by the user
                      incoming().diff(existing()).affectedKeys().hasOnly(['username', 'profilePictureUrl', 'bankCards', 'phoneNumber', 'phone', 'fullName', 'email'])
                    )) || isAdmin();
    }

    // 2. Transactions Collection
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (isOwner(existing().uid) || isAdmin());
      allow list: if isSignedIn() && (request.query.limit <= 100 && (isAdmin() || resource.data.uid == request.auth.uid));
      
      allow create: if isSignedIn() && isOwner(incoming().uid) && isValidTransaction(incoming()) && 
                       incoming().status == 'pending'; // Users can only create pending transactions
      
      allow update: if isAdmin(); // Only admins can approve/reject transactions
      allow delete: if isAdmin();
    }

    // 3. Global Config
    match /config/{configId} {
      allow read: if true; // Public config
      allow write: if isAdmin();
    }

    match /game_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /global_images/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Admin List
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via Google Cloud Console for security
    }
  }
}
