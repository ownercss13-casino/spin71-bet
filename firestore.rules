rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Connectivity test
    match /test/connection {
      allow read, write: if true;
    }

    // Helper Primitives
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'owner.css13@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Entity Validations
    function isValidUser(data) {
      return (data.username is string && data.username.size() <= 50) &&
             (data.balance is number && data.balance >= 0) &&
             (!('vipLevel' in data) || data.vipLevel is int) &&
             (!('totalTurnover' in data) || data.totalTurnover is number);
    }
    function isNewUser(data) {
      return data.keys().hasAll(['username', 'balance']) && isValidUser(data);
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['uid', 'amount', 'type', 'status']) &&
             (data.uid == request.auth.uid || data.type == 'bonus') &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'withdrawal', 'bonus'] &&
             data.status in ['pending', 'approved', 'rejected'] &&
             (!('method' in data) || data.method is string) &&
             (!('senderNumber' in data) || data.senderNumber is string) &&
             (!('trxId' in data) || data.trxId is string) &&
             (!('description' in data) || data.description is string) &&
             (!('date' in data) || data.date is string) &&
             (!('userId' in data) || data.userId is string) &&
             (!('username' in data) || data.username is string) &&
             (!('createdAt' in data) || true);
    }


    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow unauthenticated lookup by unique fields with limit 1
      allow list: if request.query.limit <= 1;
      
      // Allow admins to list all, and users to list their own referrals
      allow list: if isSignedIn() && (isAdmin() || resource.data.referredBy == request.auth.uid);
      
      allow create: if isOwner(userId) && isNewUser(incoming()) && 
                       incoming().balance == 507 && // New users start with 507 bonus
                       (!('vipLevel' in incoming()) || incoming().vipLevel == 0);
      
      allow update: if (isOwner(userId) && isValidUser(incoming()) && (
                      // Only allow updating certain fields by the user
                      incoming().diff(existing()).affectedKeys().hasOnly(['username', 'profilePictureUrl', 'bankCards', 'phoneNumber', 'phone', 'fullName', 'email', 'balance', 'lastDailyBonusClaimedAt', 'hasClaimedWelcomeBonus', 'isVerified', 'totalWithdraws', 'country', 'totalReferralEarnings', 'claimedRewards', 'referralCount'])
                    )) || 
                    (isSignedIn() && 
                     incoming().diff(existing()).affectedKeys().hasOnly(['referralCount', 'balance', 'totalReferralEarnings'])
                    ) || isAdmin();
    }

    // 2. Transactions Collection
    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (isOwner(existing().uid) || isAdmin());
      allow list: if isAdmin() || (isSignedIn() && (resource.data.uid == request.auth.uid || resource.data.userId == request.auth.uid));
      
      allow create: if isSignedIn() && (isOwner(incoming().uid) || incoming().type == 'bonus') && isValidTransaction(incoming()) && 
                       (incoming().status == 'pending' || incoming().status == 'approved');
      
      allow update: if isAdmin(); // Only admins can approve/reject transactions
      allow delete: if isAdmin();
    }

    // 3. Global Config
    match /config/{configId} {
      allow read: if true; // Public config
      allow write: if isAdmin();
    }

    match /game_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /global_images/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Admin List
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable via Google Cloud Console for security
    }
  }
}
