{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and balance information",
      "type": "object",
      "properties": {
        "username": { "type": "string", "description": "Display name" },
        "phoneNumber": { "type": "string", "description": "Verified phone number" },
        "balance": { "type": "number", "description": "Current coins" },
        "role": { "type": "string", "enum": ["user", "agent", "admin"] },
        "referredBy": { "type": "string", "description": "UID of referrer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "balance", "role"]
    },
    "GameSettings": {
      "title": "Game Settings",
      "description": "Global configuration for games",
      "type": "object",
      "properties": {
        "game_id": { "type": "string" },
        "name": { "type": "string" },
        "logo_url": { "type": "string" },
        "game_url": { "type": "string" },
        "options": { "type": "string" },
        "category": { "type": "string" },
        "image_url": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Deposit, withdraw, or bonus history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "bonus"] },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "rejected"] },
        "method": { "type": "string" },
        "trxId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/game_settings/{gameId}": {
      "schema": "GameSettings",
      "description": "Global game configuration"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transaction history for admins"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User personal transaction history"
    },
    "/promo_codes/{code}": {
      "schema": {
        "type": "object",
        "properties": {
          "code": { "type": "string" },
          "amount": { "type": "number" },
          "maxUses": { "type": "number" },
          "usedCount": { "type": "number" },
          "active": { "type": "boolean" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Promotional codes"
    },
    "/metadata/settings": {
      "schema": {
        "type": "object",
        "description": "Global application settings"
      },
      "description": "App settings"
    }
  }
}
