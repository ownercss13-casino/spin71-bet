{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user account information, balance, and levels.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "balance": { "type": "number" },
        "totalDeposits": { "type": "number" },
        "totalWithdrawals": { "type": "number" },
        "totalTurnover": { "type": "number" },
        "vipLevel": { "type": "integer" },
        "vipPoints": { "type": "number" },
        "referralCode": { "type": "string" },
        "referralCount": { "type": "integer" },
        "validReferralCount": { "type": "integer" },
        "totalReferralEarnings": { "type": "number" },
        "referredBy": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "role": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "isBlocked": { "type": "boolean" },
        "dailyDepositLimit": { "type": "number" },
        "profilePictureUrl": { "type": "string" },
        "bankCards": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "balance"]
    },
    "GameProvider": {
      "title": "Game Provider",
      "description": "Configuration for third-party game providers.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "apiKey": { "type": "string" },
        "apiEndpoint": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "Report": {
        "title": "Automated Report",
        "description": "Configuration for automated reporting.",
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "frequency": { "type": "string" },
          "recipientEmail": { "type": "string" }
        }
      },
    "Transaction": {
      "title": "Transaction Record",
      "description": "Records of deposits and withdrawals.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["deposit", "withdrawal"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "method": { "type": "string" },
        "senderNumber": { "type": "string" },
        "trxId": { "type": "string" },
        "description": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "amount", "type", "status"]
    },
    "GlobalConfig": {
      "title": "Global Application Configuration",
      "description": "Settings for the casino name, notice text, etc.",
      "type": "object",
      "properties": {
        "casinoName": { "type": "string" },
        "noticeText": { "type": "string" },
        "globalLogos": { "type": "object" },
        "globalNames": { "type": "object" }
      }
    },
    "SlotBet": {
      "title": "Slot Machine Bet",
      "description": "Record of a slot spin and its outcome.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "betAmount": { "type": "number" },
        "winAmount": { "type": "number" },
        "symbols": { "type": "array" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "betAmount", "winAmount"]
    },
    "DailyReward": {
      "title": "Daily Reward Claim",
      "description": "Tracking daily login bonuses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "lastClaimed": { "type": "string", "format": "date-time" },
        "currentStreak": { "type": "integer" }
      }
    },
    "GameSetting": {
      "title": "Game Visual Configuration",
      "description": "Store game logos, names, and custom URLs.",
      "type": "object",
      "properties": {
        "game_id": { "type": "string" },
        "name": { "type": "string" },
        "logo_url": { "type": "string" },
        "game_url": { "type": "string" },
        "provider_option": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "SupportTicket": {
      "title": "Support Ticket",
      "description": "User support inquiries.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Admin": {
        "title": "Admin",
        "description": "Admin users list.",
        "type": "object",
        "properties": {
            "role": { "type": "string" }
        }
    },
    "Bet": {
      "title": "Bet Record",
      "description": "History of all bets made by users.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "betAmount": { "type": "number" },
        "winAmount": { "type": "number" },
        "gameType": { "type": "string" },
        "symbols": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "betAmount", "winAmount"]
    },
    "SystemLog": {
      "title": "System Log Entry",
      "description": "Critical event logs for auditing system, user and administrative actions.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "action": { "type": "string" },
        "details": { "type": "object" },
        "userId": { "type": "string" },
        "adminId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "action", "createdAt"]
    },
    "BannerClick": {
      "title": "Banner Click Engagement Metric",
      "description": "Logged user clicks/taps on home screen hero promotional banners.",
      "type": "object",
      "properties": {
        "bannerId": { "type": "string" },
        "bannerTitle": { "type": "string" },
        "userId": { "type": "string" },
        "username": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["bannerId", "timestamp"]
    },
    "Notification": {
      "title": "User Notification",
      "description": "Personalized inbox messages, bonus alerts, and promotions.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["bonus", "promotion", "system", "info"] },
        "read": { "type": "boolean" },
        "sender": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "read"]
    },
    "Metadata": {
      "title": "Application Metadata",
      "description": "Dynamic settings for the UI, links, and limits.",
      "type": "object",
      "properties": {
        "casinoName": { "type": "string" },
        "noticeText": { "type": "string" },
        "telegramLink": { "type": "string" },
        "whatsappLink": { "type": "string" },
        "minDeposit": { "type": "number" },
        "minWithdraw": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/banner_clicks/{clickId}": {
      "schema": "BannerClick",
      "description": "Metric records of user clicks on main hero banners."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User documents keyed by their Firebase Auth UID."
    },
    "/users/{userId}/notifications/{notifId}": {
      "schema": "Notification",
      "description": "Subcollection for user-specific inbox notifications."
    },
    "/metadata/{docId}": {
      "schema": "Metadata",
      "description": "Global application metadata and settings."
    },
    "/game_settings/{gameId}": {
      "schema": "GameSetting",
      "description": "Visual settings and URLs for individual games."
    },
    "/game_providers/{providerId}": {
      "schema": "GameProvider",
      "description": "Third-party game provider configurations."
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Automated report configurations."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "All financial transactions."
    },
    "/config/main": {
      "schema": "GlobalConfig",
      "description": "The main global configuration document."
    },
    "/bets/{betId}": {
      "schema": "Bet",
      "description": "History of all bets."
    },
    "/daily_rewards/{userId}": {
      "schema": "DailyReward",
      "description": "Daily reward status per user."
    },
    "/support_tickets/{ticketId}": {
        "schema": "SupportTicket",
        "description": "User support tickets."
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of admin users."
    },
    "/system_logs/{logId}": {
      "schema": "SystemLog",
      "description": "Collection of system-wide logs for audit trails."
    }
  }
}

