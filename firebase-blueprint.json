{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "User's unique username"
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's registered phone number"
        },
        "password": {
          "type": "string",
          "description": "User's hashed password"
        },
        "gmail": {
          "type": "string",
          "description": "User's linked Gmail address"
        },
        "balance": {
          "type": "number",
          "description": "User's current account balance"
        },
        "isGmailLinked": {
          "type": "boolean",
          "description": "Whether the user has linked their Gmail"
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of favorite game IDs"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account creation timestamp"
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL or base64 string of the user's profile picture"
        },
        "claimedBonuses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of claimed bonus IDs"
        },
        "lastDailyBonusClaimedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last daily bonus claim"
        },
        "hasClaimedWelcomeBonus": {
          "type": "boolean",
          "description": "Whether the user has claimed the welcome bonus"
        },
        "hasMadeDeposit": {
          "type": "boolean",
          "description": "Whether the user has made at least one deposit"
        },
        "role": {
          "type": "string",
          "enum": ["user", "agent", "admin"],
          "description": "User's role in the system"
        },
        "agentBalance": {
          "type": "number",
          "description": "Balance available for the agent to distribute to their players"
        },
        "referredBy": {
          "type": "string",
          "description": "UID of the agent who referred this user"
        },
        "referralCount": {
          "type": "number",
          "description": "Total number of successful referrals"
        },
        "totalReferralEarnings": {
          "type": "number",
          "description": "Total earnings from referrals"
        }
      },
      "required": ["username", "phoneNumber", "password", "balance", "role"]
    },
    "Referral": {
      "title": "Referral",
      "description": "Information about a user referral",
      "type": "object",
      "properties": {
        "referredUserId": {
          "type": "string",
          "description": "UID of the user who was referred"
        },
        "referredUsername": {
          "type": "string",
          "description": "Username of the referred user"
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user joined via the referral"
        },
        "earningsGenerated": {
          "type": "number",
          "description": "Total earnings generated for the agent by this user"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "Current status of the referred user"
        }
      },
      "required": ["referredUserId", "referredUsername", "joinedAt", "earningsGenerated", "status"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (deposit, withdrawal, bonus, or bet)",
      "type": "object",
      "properties": {
        "trxId": {
          "type": "string",
          "description": "Unique transaction identifier"
        },
        "method": {
          "type": "string",
          "description": "Payment method (e.g., bKash, Nagad, Rocket, Wallet, System)"
        },
        "type": {
          "type": "string",
          "enum": ["deposit", "withdraw", "bonus", "bet"],
          "description": "Type of transaction"
        },
        "amount": {
          "type": "number",
          "description": "Transaction amount (positive for deposits/bonuses, negative for withdrawals/bets)"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the transaction"
        },
        "status": {
          "type": "string",
          "enum": ["সম্পন্ন", "প্রক্রিয়াধীন", "ব্যর্থ"],
          "description": "Status of the transaction in Bengali"
        },
        "statusColor": {
          "type": "string",
          "description": "Tailwind color class for the status"
        }
      },
      "required": ["trxId", "method", "type", "amount", "date", "status", "statusColor"]
    },
    "SavedItem": {
      "title": "SavedItem",
      "description": "Items saved by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user who saved the item"
        },
        "itemId": {
          "type": "string",
          "description": "ID of the saved item"
        },
        "itemType": {
          "type": "string",
          "description": "Type of the saved item (e.g., game, product)"
        },
        "savedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the item was saved"
        }
      },
      "required": ["userId", "itemId", "itemType", "savedAt"]
    },
    "Metadata": {
      "title": "Metadata",
      "description": "System-wide metadata and counters",
      "type": "object",
      "properties": {
        "userCount": {
          "type": "integer",
          "description": "Total number of users registered"
        }
      }
    },
    "GameSession": {
      "title": "GameSession",
      "description": "Shared state for a live game session",
      "type": "object",
      "properties": {
        "gameId": { "type": "string" },
        "multiplier": { "type": "number" },
        "status": { "type": "string", "enum": ["waiting", "running", "crashed"] },
        "crashPoint": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "lastUpdate": { "type": "string", "format": "date-time" },
        "history": { "type": "array", "items": { "type": "number" } }
      },
      "required": ["gameId", "multiplier", "status", "lastUpdate"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification for the user",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "Notification title"
        },
        "message": {
          "type": "string",
          "description": "Notification message body"
        },
        "type": {
          "type": "string",
          "enum": ["bonus", "promotion", "account", "system"],
          "description": "Type of notification"
        },
        "read": {
          "type": "boolean",
          "description": "Whether the notification has been read"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the notification was created"
        },
        "actionUrl": {
          "type": "string",
          "description": "Optional URL to navigate to when clicked"
        }
      },
      "required": ["title", "message", "type", "read", "createdAt"]
    },
    "GlobalConfig": {
      "title": "GlobalConfig",
      "description": "Global system-wide configuration settings",
      "type": "object",
      "properties": {
        "game_logos": {
          "type": "object",
          "description": "Map of game IDs to their global logo URLs"
        },
        "game_names": {
          "type": "object",
          "description": "Map of game IDs to their global names"
        }
      }
    },
    "ApiToken": {
      "title": "ApiToken",
      "description": "API token for external system access",
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "description": "The actual API token string"
        },
        "name": {
          "type": "string",
          "description": "Name of the API token"
        },
        "expirationDate": {
          "type": "string",
          "format": "date",
          "description": "Expiration date of the token"
        },
        "status": {
          "type": "string",
          "enum": ["active", "inactive"],
          "description": "Status of the token"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp"
        }
      },
      "required": ["token", "name", "expirationDate", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document stored by their unique UID"
    },
    "/users/{userId}/savedItems/{savedItemId}": {
      "schema": "SavedItem",
      "description": "Collection of items saved by a specific user"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial history for a specific user"
    },
    "/users/{userId}/referrals/{referralId}": {
      "schema": "Referral",
      "description": "Collection of users referred by this agent"
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Collection of notifications for a specific user"
    },
    "/metadata/users": {
      "schema": "Metadata",
      "description": "Document containing the user counter"
    },
    "/game_sessions/{gameId}": {
      "schema": "GameSession",
      "description": "Shared state for a specific game (e.g., aviator)"
    },
    "/global_config/{configId}": {
      "schema": "GlobalConfig",
      "description": "Global configuration settings accessible to all users"
    },
    "/api_tokens/{tokenId}": {
      "schema": "ApiToken",
      "description": "Collection of API tokens for admin access"
    }
  }
}
