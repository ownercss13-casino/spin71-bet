{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and account information",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "User's unique username"
        },
        "phoneNumber": {
          "type": "string",
          "description": "User's registered phone number"
        },
        "password": {
          "type": "string",
          "description": "User's hashed password"
        },
        "gmail": {
          "type": "string",
          "description": "User's linked Gmail address"
        },
        "balance": {
          "type": "number",
          "description": "User's current account balance"
        },
        "isGmailLinked": {
          "type": "boolean",
          "description": "Whether the user has linked their Gmail"
        },
        "favorites": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of favorite game IDs"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Account creation timestamp"
        },
        "profilePictureUrl": {
          "type": "string",
          "description": "URL or base64 string of the user's profile picture"
        },
        "claimedBonuses": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of claimed bonus IDs"
        },
        "lastDailyBonusClaimedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last daily bonus claim"
        },
        "hasClaimedWelcomeBonus": {
          "type": "boolean",
          "description": "Whether the user has claimed the welcome bonus"
        },
        "hasMadeDeposit": {
          "type": "boolean",
          "description": "Whether the user has made at least one deposit"
        },
        "referralCount": {
          "type": "number",
          "description": "Total number of successful referrals"
        },
        "totalReferralEarnings": {
          "type": "number",
          "description": "Total earnings from referrals"
        }
      },
      "required": ["username", "phoneNumber", "password", "balance"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction (deposit, withdrawal, bonus, or bet)",
      "type": "object",
      "properties": {
        "trxId": {
          "type": "string",
          "description": "Unique transaction identifier"
        },
        "method": {
          "type": "string",
          "description": "Payment method (e.g., bKash, Nagad, Rocket, Wallet, System)"
        },
        "type": {
          "type": "string",
          "enum": ["deposit", "withdraw", "bonus", "bet"],
          "description": "Type of transaction"
        },
        "amount": {
          "type": "number",
          "description": "Transaction amount (positive for deposits/bonuses, negative for withdrawals/bets)"
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the transaction"
        },
        "status": {
          "type": "string",
          "enum": ["সম্পন্ন", "প্রক্রিয়াধীন", "ব্যর্থ"],
          "description": "Status of the transaction in Bengali"
        },
        "statusColor": {
          "type": "string",
          "description": "Tailwind color class for the status"
        }
      },
      "required": ["trxId", "method", "type", "amount", "date", "status", "statusColor"]
    },
    "SavedItem": {
      "title": "SavedItem",
      "description": "Items saved by the user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "ID of the user who saved the item"
        },
        "itemId": {
          "type": "string",
          "description": "ID of the saved item"
        },
        "itemType": {
          "type": "string",
          "description": "Type of the saved item (e.g., game, product)"
        },
        "savedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the item was saved"
        }
      },
      "required": ["userId", "itemId", "itemType", "savedAt"]
    },
    "Metadata": {
      "title": "Metadata",
      "description": "System-wide metadata and counters",
      "type": "object",
      "properties": {
        "userCount": {
          "type": "integer",
          "description": "Total number of users registered"
        }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User document stored by their unique UID"
    },
    "/users/{userId}/savedItems/{savedItemId}": {
      "schema": "SavedItem",
      "description": "Collection of items saved by a specific user"
    },
    "/users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Financial history for a specific user"
    },
    "/metadata/users": {
      "schema": "Metadata",
      "description": "Document containing the user counter"
    }
  }
}
